# ─── API cấu hình chung cho toàn bộ AI trong dự án ───
# Sử dụng OpenAI-compatible API (CES Router)
# Base URL và API Key dùng chung cho cả Chatbot (server-side) và Copilot (client-side)

# Chatbot AI (Server-Side - API Route)
OPENAI_BASE_URL=https://your-api-base-url.com/v1
OPENAI_API_KEY=sk-your-api-key-here

# AI Copilot - Page Agent (Client-Side)
# NEXT_PUBLIC_ prefix để Next.js expose ra phía client
NEXT_PUBLIC_LLM_BASE_URL=https://your-api-base-url.com/v1
NEXT_PUBLIC_LLM_API_KEY=sk-your-api-key-here
